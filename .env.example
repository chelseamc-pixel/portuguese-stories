# Copy this file to .env and fill in your values (for local development only)
# Never commit .env to git!

# Gemini API key — get at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API key — get at: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs voice ID — browse voices at: https://elevenlabs.io/voice-library
# Recommended: find a female European Portuguese voice, copy its ID
# Default falls back to Rachel (multilingual model handles PT-PT pronunciation)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Gmail credentials
GMAIL_USER=chelseamc@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here  # NOT your regular Gmail password

# Who receives the email (defaults to GMAIL_USER if not set)
RECIPIENT_EMAIL=chelseamc@gmail.com

# GitHub Pages config (used to construct the story URL in the email)
GITHUB_USERNAME=chelseamc-pixel
GITHUB_REPO=portuguese-stories
